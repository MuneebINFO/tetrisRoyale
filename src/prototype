// Fonction pour détecter si une touche a été pressée
bool ifPressed() {
    struct termios oldt, newt;//structure pour stocker les paramètres du terminal
    int ch;                   //variable pour stocker le caractère saisi
    int oldf;                 //variable pour stocker les indicateurs originaux du descripteur de fichier

