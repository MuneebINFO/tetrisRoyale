// Vérifie si le tétrimino peut être placé
bool canPlaceTetrimino(const Tetrimino& tetrimino) {
    int rows = tetrimino.shape.size();
    int cols = tetrimino.shape[0].size();

    for (int i = 0; i < rows; ++i) {
        for (int j = 0; j < cols; ++j) {
            if (tetrimino.shape[i][j] == 1) {
                int x = tetrimino.x + i;
                int y = tetrimino.y + j;

                if (x < 0 || x >= height || y < 0 || y >= width || grid[x][y] != 0) {
                    return false;
                }
            }
        }
    }
    return true;
}

// Fonction pour gérer la rotation d'un tetrimino
void rotateTetrimino(Tetrimino& tetrimino, bool clockwise = true) {
    vector<vector<int>> rotated;

    int rows = tetrimino.shape.size();
    int cols = tetrimino.shape[0].size();

    if (clockwise) {   // tourner le tetrimino en sens horlogique
        rotated.resize(cols, vector<int>(rows));
        for (int i = 0; i < rows; ++i) {
            for (int j = 0; j < cols; ++j) {
                rotated[j][rows - 1 - i] = tetrimino.shape[i][j];
            }
        }
    }
    else {       // tourner le tetrimino en sens anti horlogique
        rotated.resize(cols, vector<int>(rows));
        for (int i = 0; i < rows; ++i) {
            for (int j = 0; j < cols; ++j) {
                rotated[cols - 1 - j][i] = tetrimino.shape[i][j];
            }
        }
    }

    // Pour appliquer la rotation ssi elle est valide
    Tetrimino temp = tetrimino;
    temp.shape = rotated;
    if (canPlaceTetrimino(temp)) {
        tetrimino.shape = rotated;
    }
}

// Déplace le tétrimino
bool moveTetrimino(Tetrimino& tetrimino, int dx, int dy) {
    tetrimino.x += dx;
    tetrimino.y += dy;
    if (!canPlaceTetrimino(tetrimino)) {
        tetrimino.x -= dx;
        tetrimino.y -= dy;
        return false;
    }
    return true;
}

// Fixe le tétrimino sur la grille
void placeTetrimino(const Tetrimino& tetrimino) {
    int rows = tetrimino.shape.size();
    int cols = tetrimino.shape[0].size();

    for (int i = 0; i < rows; ++i) {
        for (int j = 0; j < cols; ++j) {
            if (tetrimino.shape[i][j] == 1) {
                grid[tetrimino.x + i][tetrimino.y + j] = 1;
                colorGrid[tetrimino.x + i][tetrimino.y + j] = tetrimino.color;
            }
        }
    }
}


// Efface les lignes complètes
void clearFullRows() {
    for (int i = height - 1; i >= 0; --i) {
        // Verifie si la ligne est complete
        if (all_of(grid[i].begin(), grid[i].end(), [](int cell) { return cell != 0; })) {
            // Supprime la ligne qui est complete
            grid.erase(grid.begin() + i);
            colorGrid.erase(colorGrid.begin() + i);

            // Insere une nouvelle ligne vide en haut
            vector<int> newLine(width, 0);
            vector<const char*> newColorLine(width, nullptr);
            grid.insert(grid.begin(), newLine);
            colorGrid.insert(colorGrid.begin(), newColorLine);

            // Passe a la ligne suivante
            ++i;
            points += 100;
        }
    }
}


// Génère un tétrimino aléatoire
Tetrimino generateRandomTetrimino() {
    int shapeIndex = rand() % shapes.size();

    // Si toutes les couleurs ont éte utlisées, on réinitialise
    if (previousColors.size() == 7) { previousColors.clear(); }

    // Pour choisir une couleur differente des precedentes
    const char* color;
    do {
        color = colors[rand() % 7];
    } while (find(previousColors.begin(), previousColors.end(), color) != previousColors.end());

    previousColors.push_back(color);

    return Tetrimino(0, width / 2 - shapes[shapeIndex][0].size() / 2, shapes[shapeIndex], color);
}

